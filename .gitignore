# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
qwen-env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially generated by the workflow
generated_images/
# Если нужно сохранять историю промптов, то не игнорируем prompt_history.json
# Но большие файлы изображений лучше исключить
# Однако, если пользователь хочет версионировать сгенерированные изображения, то раскомментируем ниже
# Но обычно это плохая идея из-за размера
# Тем не менее, оставим решение за пользователем, пока исключаем только очень большие файлы? 
# Пока исключаем всю директорий generated_images, но пользователь может передумать.

# Логи
*.log

# Временные файлы
*.tmp
*.temp

# MLX специфичное
# Возможно, есть какие-то кэши или временные файлы от MLX
# Пока не добавляем специфичные исключения, если они известны

# Исключаем большие файлы, если они не нужны в репозитории
# Но оставляем возможность отслеживать небольшие файлы
# Например, если в generated_images есть только несколько маленьких превью, можно не исключать
# Однако, по умолчанию исключаем всё содержимое
generated_images/*

# Но сохраняем саму директорию в репозитории (как пустую)
!generated_images/
!generated_images/.gitkeep

# Аналогично для других директорий, которые могут быть пустыми, но нужны